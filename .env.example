# LLM Backend
# Options: ollama
LLM_BACKEND=

# --- Ollama ---
# Local: http://localhost:11434
# Docker (Ollama on host machine): http://host.docker.internal:11434
# Remote: https://your-ollama-host
OLLAMA_BASE_URL=
OLLAMA_MODEL=
OLLAMA_EMBED_MODEL=
OLLAMA_VISION_MODEL=
CHROMA_PATH=

# chunk settings
# default 512
CHUNK_SIZE=
# default 64
CHUNK_OVERLAP=


# LLM Backend
# Options: ollama, openai
LLM_BACKEND=
# --- Ollama ---
# Local: http://localhost:11434
# Docker (Ollama on host machine): http://host.docker.internal:11434
# Remote: https://your-ollama-host
OLLAMA_BASE_URL=
OLLAMA_MODEL=
OLLAMA_EMBED_MODEL=
OLLAMA_VISION_MODEL=
CHROMA_PATH=

# --- chunk settings ---
CHUNK_SIZE=
CHUNK_OVERLAP=

# --- OpenAI ---
# Use LLM_BACKEND=openai
#
# OpenAI: https://api.openai.com/v1
# Local/proxy: http://localhost:8001/v1
# Hosted proxy: https://your-openai-host/v1
OPENAI_BASE_URL=
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=
OPENAI_EMBED_MODEL=
OPENAI_VISION_MODEL=

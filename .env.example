# LLM backends
# LLM_BACKEND drives chat/generate/stream/vision. EMBED_BACKEND (optional)
# routes embeddings to a separate provider. Options: ollama, openai/litellm,
# anthropic. Example split: chat on Anthropic, embeddings on an OpenAI-compatible
# LiteLLM endpoint -> LLM_BACKEND=anthropic, EMBED_BACKEND=openai
LLM_BACKEND=
EMBED_BACKEND=
CHROMA_PATH=


# --- Anthropic (Claude) ---
# Use LLM_BACKEND=anthropic. Anthropic has no embeddings API, so pair it with an
# EMBED_BACKEND that does. Claude is multimodal; ANTHROPIC_VISION_MODEL defaults
# to ANTHROPIC_CHAT_MODEL.
ANTHROPIC_API_KEY=
ANTHROPIC_CHAT_MODEL=claude-haiku-4-5
ANTHROPIC_VISION_MODEL=
ANTHROPIC_MAX_TOKENS=4096
# Optional override (e.g. a proxy). Defaults to https://api.anthropic.com
ANTHROPIC_BASE_URL=

# --- Ollama ---
# Local: http://localhost:11434
# Docker (Ollama on host machine): http://host.docker.internal:11434
# Remote: https://your-ollama-host
OLLAMA_BASE_URL=
OLLAMA_MODEL=
OLLAMA_EMBED_MODEL=
OLLAMA_VISION_MODEL=
# Context window. Leave empty for Ollama's default (~4096), which silently
# truncates large prompts and breaks onboarding synthesis. Set to your model's
# window, e.g. 32768.
OLLAMA_NUM_CTX=

# --- OpenAI-compatible (OpenAI / LiteLLM / proxy) ---
# Use LLM_BACKEND=openai or EMBED_BACKEND=openai.
# OpenAI: https://api.openai.com/v1
OPENAI_BASE_URL=
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=
OPENAI_EMBED_MODEL=
OPENAI_VISION_MODEL=


# Set to 1 to log each agent's reasoning step (LLM text + tool calls) to stderr.
# AGENT_DEBUG=0

# --- chunk settings ---
CHUNK_SIZE=
CHUNK_OVERLAP=


